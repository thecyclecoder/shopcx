# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local data files
/tmp/
/gorgias*
/shopcx-product-spec.html

# typescript
*.tsbuildinfo
next-env.d.ts
twilio-recovery.txt
.claude/worktrees/

# ad-tool example render assets (binary, regenerated locally)
remotion/public/adbuild/

# scratch / one-off debug scripts
scripts/_*
# ...except the shared, committed bootstrap (the foundation every script imports)
!scripts/_bootstrap.ts
# ...and committed audit/utility scripts the brain refers to by their spec-mandated names.
!scripts/_audit-spec-phase-overcount.ts
