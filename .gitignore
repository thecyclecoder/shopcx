.box/

# ad-tool example render assets (binary, regenerated locally)
remotion/public/adbuild/

# scripts convention: underscore (`scripts/_*`) scripts ARE COMMITTED by default.
# Only throwaways are ignored — name them with the `_tmp-` or `_scratch-` prefix and they
# stay out of git; everything else (`_bootstrap.ts`, `_audit-*.ts`, `_check-*.ts`, `_verify-*.ts`,
# `_probe-*.ts`, customer-remedy one-offs the brain refers to by name, …) is tracked with no
# per-file negation needed. This replaces the old `scripts/_*` blanket-ignore + growing
# `!scripts/_foo.ts` allow-list, which silently dropped any new committed underscore-script that
# nobody remembered to negate.
scripts/_tmp-*
scripts/_scratch-*
