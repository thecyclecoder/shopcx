{%- comment -%}
  This page now HANDS OFF to the in-house portal (portal.superfoodscompany.com)
  instead of rendering the embedded subscriptions portal SPA.

  - Logged in  → /apps/portal-v2?route=sso : the App Proxy attaches the verified
    logged_in_customer_id, our `sso` handler mints a magic-link and 302s the
    customer into the portal already authenticated (no second login).
  - Logged out → straight to the portal, where they sign in (login-help chat there).

  Liquid `{% if customer %}` decides the target at render time; no app JS loads.
{%- endcomment -%}

{%- if customer -%}
  {%- assign portal_target = '/apps/portal-v2?route=sso' -%}
{%- else -%}
  {%- assign portal_target = 'https://portal.superfoodscompany.com/' -%}
{%- endif -%}

<div class="subscriptions-portal" data-app="subscriptions-portal">
  {%- if request.design_mode -%}
    <div style="padding:14px; border:1px dashed #d1d5db; border-radius:10px;">
      <strong>Subscriptions Portal</strong>
      <p style="margin:6px 0 0; color:#6b7280;">
        On the live storefront this page redirects to portal.superfoodscompany.com
        ({% if customer %}signed in via SSO{% else %}sign-in{% endif %}). Redirect is
        suppressed here in the theme editor.
      </p>
    </div>
  {%- else -%}
    <script>
      window.location.replace({{ portal_target | json }});
    </script>
    <noscript>
      <meta http-equiv="refresh" content="0; url={{ portal_target }}">
    </noscript>
    <p style="text-align:center; padding:24px; color:#6b7280;">Taking you to your account…</p>
  {%- endif -%}
</div>
{% schema %}
{
  "name": "Subscriptions Portal",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Subscribe & Save"
    },
    {
      "type": "text",
      "id": "workspace_id",
      "label": "ShopCX Workspace ID",
      "info": "Your ShopCX workspace ID. The backend validates this against the connected Shopify store."
    },
    {
      "type": "checkbox",
      "id": "redirect_to_login",
      "label": "Auto-redirect to login when logged out",
      "default": true
    }
  ]
}
{% endschema %}
